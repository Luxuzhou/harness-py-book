# ========================================
# 《HarnessEngineering实战：构建可靠的生产级AIAgent》
# 配套代码仓库 .gitignore
# ========================================

# === Python ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.whl

# === 虚拟环境 ===
.venv/
venv/
env/

# === API 密钥（绝对不能提交） ===
.env
.env.local
.env.production

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === 测试与缓存 ===
.pytest_cache/
htmlcov/
.coverage
target/

# === 运行时临时目录（pytest / Agent 产物） ===
tmp_test/
tests_runtime_tmp/
.tmp/
.tmp_test/

# === Agent 运行产生的 session 数据 ===
.harness_sessions/
*.log.jsonl
compliance_log.jsonl

# === 实验运行结果（读者自己跑产生） ===
experiments/results/

# === 合规案例运行时产出（读者自己跑产生） ===
cases/*/output/
cases/data_compliance/target_service/exports/
cases/data_compliance/target_service/audit_logs/
cases/data_compliance/target_service/reports/
cases/data_compliance/target_service/notifications/

# === 运行时数据库和日志 ===
*.db
inventory.log
*.log

# === 其他 Agent 工具配置（和本项目无关） ===
.omx/
.codex/
.claude/
node_modules/

# === Word 文档（出版社交付物，不入仓库） ===
*.docx

# === 大文件 ===
*.duckdb
*.duckdb.wal
*.tar.gz
